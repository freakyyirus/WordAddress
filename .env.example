# ─────────────────────────────────────────────────────────────
# Open3Words Environment Configuration
# Copy this file to .env and adjust values for your environment.
# ─────────────────────────────────────────────────────────────

# ── Backend ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
DATABASE_URL=postgresql://o3w:o3w_secret@localhost:5432/open3words

# ── AI / Voice Services ─────────────────────────────────────
WHISPER_URL=http://localhost:9000
OLLAMA_URL=http://localhost:11434

# ── Blockchain (optional) ───────────────────────────────────
WEB3_RPC_URL=http://localhost:8545
CONTRACT_ADDRESS=
PRIVATE_KEY=

# ── Grid System ─────────────────────────────────────────────
# Options: default, s2, h3
DEFAULT_GRID=default

# ── Language ─────────────────────────────────────────────────
DEFAULT_LANG=en

# ── API ──────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=2
LOG_LEVEL=info
